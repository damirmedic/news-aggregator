# Copy to .env and fill in. All values below are the defaults used if unset.

# --- LLM ---
# LLM_MODE controls the two summarization calls:
#   stub    -> deterministic placeholder output, NO API calls, no key needed
#   gemini  -> Google Gemini API (requires GEMINI_API_KEY) - free tier, no card
#   live    -> Anthropic Claude API (requires ANTHROPIC_API_KEY) - paid
# If the selected mode's key is missing, the app falls back to stub rather
# than crashing at request time.
LLM_MODE=stub

# Gemini: get a free key at https://aistudio.google.com/apikey (no card
# required). Google retires "flash-lite" model versions over time (e.g.
# gemini-2.5-flash-lite 404s for new accounts as of mid-2026) - if the
# default below stops working, list what your key can actually use:
#   curl "https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Anthropic (paid, no standing free tier - see console.anthropic.com/settings/billing)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Featured images (royalty-free stock) ---
# Each article gets an illustrative image matched to its topic from Pexels
# (free stock, permissive license), hotlinked from Pexels' CDN and credited —
# never the source's own copyrighted photo. Get a free key (no card) at
# https://www.pexels.com/api/ . If unset, every article falls back to a
# self-hosted per-category placeholder, so the pipeline still runs key-less.
PEXELS_API_KEY=
# Milliseconds to wait for the Pexels lookup before falling back to a
# placeholder (kept short so image lookups never stall an ingest run).
IMAGE_FETCH_TIMEOUT_MS=6000

# --- Selection logic (90/10 HR/world) ---
# World/EU items must score >= this (0-10) during fact extraction to be published.
WORLD_SCORE_THRESHOLD=7

# --- Freshness & retention ---
# Feed items older than this (by the source's own pubDate) are skipped before
# the costly full-text + LLM steps. 3h absorbs the deployed cron's real-world
# unreliability (GitHub scheduled runs get delayed/skipped, often running every
# 2-4h instead of hourly) so a missed run doesn't become a permanent gap.
# URL-dedupe already prevents reprocessing, so a wider window costs nothing but
# "freshest ~3h" instead of "freshest 1h".
FETCH_MAX_AGE_HOURS=3
# How long a published article stays on the live site (front page + detail
# page). The underlying DB row is kept indefinitely either way.
ARTICLE_RETENTION_DAYS=7

# --- Cross-portal duplicate detection ---
# How far back to compare new articles against for "same story, different
# portal" detection.
DEDUPE_WINDOW_HOURS=48
# Weighted-Jaccard similarity (shared named entities + numbers + event wording;
# see src/pipeline/dedupe.js) above which two articles are treated as the same
# story and the later one dropped. 0-1; raise it to merge less, lower to merge
# more aggressively.
DEDUPE_SIMILARITY_THRESHOLD=0.24

# --- Scheduling ---
# Minutes between ingestion runs when using `npm start` (cron scheduler).
# 60 (default) runs hourly at the top of each hour (":00").
INGEST_INTERVAL_MIN=60

# --- Storage / paths ---
DB_PATH=./data/news.db
PUBLIC_DIR=./public

# --- Preview server (`npm run serve`) ---
PORT=4173

# --- Ingestion tuning ---
# Max articles to fully process (extract + summarize) per source per run.
MAX_ITEMS_PER_SOURCE=15
# Max LLM calls per run (~2 per article). Rations the Gemini free tier's HARD
# DAILY cap (500 req/day for flash-lite) across ~24-29 hourly runs — without
# this, the morning's news volume exhausts the whole day's quota by midday and
# evening runs publish nothing. Over-budget items roll to the next run (newest
# first) until the freshness window ages them out.
LLM_CALLS_PER_RUN=18
# Milliseconds to wait for a network request before giving up.
FETCH_TIMEOUT_MS=15000
