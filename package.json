{
  "name": "no-clickbait-news-aggregator",
  "version": "0.1.0",
  "description": "Fully-automated Croatian news aggregator/summarizer. Ingest -> extract facts -> write plain summary -> publish. No clickbait, no human in the loop.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "migrate": "node src/index.js migrate",
    "ingest": "node src/index.js ingest",
    "generate": "node src/index.js generate",
    "serve": "node src/index.js serve",
    "start": "node src/index.js start",
    "test": "node --test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^0.15.0",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "jsdom": "^25.0.1",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0"
  }
}
